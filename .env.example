# Application
APP_NAME=Leadex
APP_ENV=development
DEBUG=true
HOST=0.0.0.0
PORT=8000
SECRET_KEY=replace-with-a-long-random-value

# Database
DATABASE_URL=postgresql+psycopg2://leadex:replace-me@127.0.0.1:5432/leadex_db

# Redis
REDIS_URL=redis://127.0.0.1:6379/0

# Hosts and CORS
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ORIGINS=http://localhost:8000

# reCAPTCHA
RECAPTCHA_SECRET_KEY=
RECAPTCHA_SITE_KEY=

# SendGrid
EMAIL_BACKEND=sendgrid
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@example.com

# Meta WhatsApp
META_ACCESS_TOKEN=
META_PHONE_NUMBER_ID=
META_BUSINESS_ACCOUNT_ID=
META_VERIFY_TOKEN=
WHATSIPLUS_API_KEY=

# Google Sheets
GOOGLE_CREDENTIALS_FILE=credentials.json
GOOGLE_SERVICE_ACCOUNT_EMAIL=

# Optional GeoIP database
GEOIP_DATABASE_PATH=/usr/share/GeoIP/GeoLite2-City.mmdb

# Lead distribution
DEDUPE_WINDOW_DAYS=20
BATCH_SIZE=1
RETRY_ATTEMPTS=3
STORED_LEADS_INTERVAL_MINUTES=1
DEFAULT_CREDIT_COST=1.0

# JWT
ACCESS_TOKEN_EXPIRE_MINUTES=10080
ALGORITHM=HS256
